<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet package metadata -->
    <PackageId>PackagerTest</PackageId>
    <Version>1.0.3</Version>
    <Authors>neilcarberry</Authors>
    <Description>Pi calculation library with a typed HTTP client for the Pi Generation Leaderboard API.</Description>
    <PackageTags>pi;leaderboard;calculator</PackageTags>
    <RepositoryUrl>https://github.com/neilcarberry/packagertest</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="openapi.yaml" Pack="true" PackagePath="content/openapi.yaml" />
  </ItemGroup>

</Project>
